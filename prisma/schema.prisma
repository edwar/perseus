generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (better-auth) ───────────────────────────────────────────

model User {
  id         String    @id
  name       String?
  email      String    @unique
  emailVerified Boolean @default(false)
  image      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  sessions          Session[]
  accounts         Account[]
  transactions     AppTransaction[]
  budgets          AppBudget[]
  debts            AppDebt[]
  recurring        AppRecurring[]
  savingGoals      AppSavingGoal[]
  investments      AppInvestment[]
  obligations      AppObligation[]
  obligationChecks AppObligationCheck[]
  obligationTemplates AppObligationTemplate[]
  obligationInstances AppObligationInstance[]
  categoryPatterns AppCategoryPattern[]

  @@map("user")
}

model Session {
  id        String    @id
  expiresAt DateTime
  token     String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String     @id
  accountId             String
  providerId            String
  userId                String
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ─── App data (one-to-one con los stores) ─────────────────────────

model AppTransaction {
  id          String   @id
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  description String
  amount      Decimal  @db.Decimal(15, 2)
  type        String   // "EXPENSE" | "INCOME"
  category    String?
  date        String   // ISO string
  recurring   Boolean  @default(false)
  frequency   String?
  nextDate    String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@map("app_transactions")
}

model AppBudget {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  String
  amount    Decimal  @db.Decimal(15, 2)
  color     String?
  items     Json     @default("[]")
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("app_budgets")
}

model AppDebt {
  id           String    @id
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  creditor     String?
  category     String?
  total        Decimal   @db.Decimal(15, 2)
  remaining    Decimal   @db.Decimal(15, 2)
  rate         Decimal   @db.Decimal(5, 2) @default(0)
  monthly      Decimal   @db.Decimal(15, 2) @default(0)
  minimum      Decimal?  @db.Decimal(15, 2)
  installments Int?
  paid         Int       @default(0)
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@map("app_debts")
}

model AppRecurring {
  id          String   @id
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  amount      Decimal  @db.Decimal(15, 2)
  type        String   // "INCOME" | "EXPENSE"
  frequency   String
  dayOfMonth  Int
  category    String?
  debtId      String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@map("app_recurring")
}

model AppSavingGoal {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  target    Decimal  @db.Decimal(15, 2)
  current   Decimal  @db.Decimal(15, 2) @default(0)
  deadline  String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("app_saving_goals")
}

model AppInvestment {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entity    String
  amount    Decimal  @db.Decimal(15, 2)
  rate      Decimal  @db.Decimal(5, 2) @default(0)
  termDays  Int
  startDate String
  endDate   String
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("app_investments")
}

model AppObligation {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())

  checks     AppObligationCheck[]

  @@index([userId])
  @@map("app_obligations")
}

model AppObligationCheck {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month         String   // "2024-01"
  obligationId  String
  obligation    AppObligation @relation(fields: [obligationId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@unique([userId, month, obligationId])
  @@map("app_obligation_checks")
}

model AppCategoryPattern {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pattern    String   // keyword or description fragment
  category   String
  confidence Float    @default(0.5) // 0-1, increases with usage
  count      Int      @default(1)   // how many times this pattern matched
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, pattern, category])
  @@index([userId])
  @@map("app_category_patterns")
}

// ─── Gamified Obligations (v2) ─────────────────────────────────────

model AppObligationTemplate {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  emoji       String   @default("📋")
  category    String?
  frequency   String   @default("daily") // daily | weekly | monthly | once
  daysOfWeek  Json?    // [1,3,5] → Lun, Mié, Vie (0=Dom, 6=Sáb)
  timesPerDay Int      @default(1)
  createdAt   DateTime @default(now())

  tasks       AppObligationTask[]
  instances   AppObligationInstance[]

  @@index([userId])
  @@map("app_obligation_templates")
}

model AppObligationTask {
  id          String   @id @default(cuid())
  templateId  String
  template    AppObligationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name        String
  emoji       String   @default("✓")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  taskInstances AppObligationTaskInstance[]

  @@index([templateId])
  @@map("app_obligation_tasks")
}

model AppObligationInstance {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId     String
  template       AppObligationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  date           String    // "2026-08-15"
  instanceNumber Int       @default(1)
  createdAt      DateTime  @default(now())

  taskInstances  AppObligationTaskInstance[]

  @@unique([userId, templateId, date, instanceNumber])
  @@index([userId, date])
  @@map("app_obligation_instances")
}

model AppObligationTaskInstance {
  id           String    @id @default(cuid())
  instanceId   String
  instance     AppObligationInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  taskId       String
  task         AppObligationTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  completed    Boolean   @default(false)
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  @@unique([instanceId, taskId])
  @@index([instanceId])
  @@map("app_obligation_task_instances")
}